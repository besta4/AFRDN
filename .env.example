# Copy to .env for local development and set secure values.
# .env is gitignored.

# JWT secret used for signing and validating auth tokens.
# Generate one with Python: import secrets; print(secrets.token_urlsafe(32))
JATAYU_JWT_SECRET=replace-with-a-strong-random-secret

# Optional: path to append-only audit log file.
JATAYU_AUDIT_FILE=data/audit.jsonl

# Optional: SQLite database path. Relative paths resolve under backend/.
JATAYU_DB_PATH=data/jatayu.db

# Optional: Redis URL for real-time graph context. Leave as localhost on a
# single EC2 instance running redis-server.
JATAYU_REDIS_URL=redis://localhost:6379/0

# Optional: opt into the bundled PPO risk policy after calibration.
JATAYU_ENABLE_PPO=0
