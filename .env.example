# Copy to .env for local development and set secure values.
# .env is gitignored.

# JWT secret used for signing and validating auth tokens.
# Generate one with Python: import secrets; print(secrets.token_urlsafe(32))
JATAYU_JWT_SECRET=replace-with-a-strong-random-secret

# Optional: path to append-only audit log file.
JATAYU_AUDIT_FILE=audit.jsonl
